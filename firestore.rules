rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default safety catch-all: reject everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation helpers
    function isValidBooking(data) {
      return data.userId == request.auth.uid
        && data.type is string && data.type.size() > 0 && data.type.size() <= 200
        && data.date is string && data.date.size() > 0 && data.date.size() <= 16
        && data.time is string && data.time.size() > 0 && data.time.size() <= 64
        && data.meetingUri is string && data.meetingUri.size() > 0 && data.meetingUri.size() <= 512
        && data.meetingCode is string && data.meetingCode.size() > 0 && data.meetingCode.size() <= 128
        && data.createdAt == request.time
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000));
    }

    function isValidInquiry(data) {
      return ((isSignedIn() && data.userId == request.auth.uid) || (!isSignedIn() && data.userId == 'anonymous_client'))
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && (!('email' in data) || (data.email is string && data.email.size() <= 128))
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.anupanaPreference is string && data.anupanaPreference.size() <= 128
        && (!('consultationNotes' in data) || (data.consultationNotes is string && data.consultationNotes.size() <= 2000))
        && data.selectedPaymentMethod in ['gpay', 'traditional']
        && data.totalPrice is number && data.totalPrice >= 0
        && data.status in ['submitted', 'processing', 'ready', 'cancelled']
        && data.createdAt == request.time
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50;
    }

    function isValidQuizResult(data) {
      return data.userId == request.auth.uid
        && data.dominantDosha is string && data.dominantDosha.size() <= 32
        && data.doshaResult is map
        && data.completedAt == request.time;
    }

    function isValidNewsletterSubscriber(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidRemedyFeedback(data) {
      return data.productId is string && data.productId.size() > 0 && data.productId.size() <= 128
        && data.userId == request.auth.uid
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() >= 0 && data.comment.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidReferral(data) {
      return data.referrerId is string && data.referrerId.size() > 0 && data.referrerId.size() <= 128
        && data.referrerName is string && data.referrerName.size() > 0 && data.referrerName.size() <= 128
        && data.friendName is string && data.friendName.size() > 0 && data.friendName.size() <= 128
        && data.friendEmail is string && data.friendEmail.size() > 0 && data.friendEmail.size() <= 128
        && data.status in ['invited', 'joined']
        && data.createdAt == request.time;
    }

    // Collection Security Rules

    // 1. Bookings collection: Only the matched patient owner can read, create, and update
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isSignedIn()
        && isValidId(bookingId)
        && isValidBooking(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'type', 'date', 'time', 'meetingUri', 'meetingCode']);
      allow delete: if false; // Consultations bookings are permanent for clinical records
    }

    // 2. Inquiries collection: Only the matched purchasing customer can read, create, or cancel
    match /inquiries/{inquiryId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow update: if isSignedIn()
        && isValidId(inquiryId)
        && isValidInquiry(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'consultationNotes']);
      allow delete: if false; // Recipies are archived permanently for medicine dispensing audit
    }

    // 3. Quiz results: User tracked history
    match /quiz_results/{resultId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(resultId) && isValidQuizResult(incoming());
      allow update: if false; // Historic quizzes can never be tampered with after submission
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 4. Newsletter Subscribers: Open creation for everyone; read access is forbidden for general users
    match /newsletter_subscribers/{subscriberId} {
      allow get, list: if false; // Isolated data protection block (PII Guard)
      allow create: if isValidId(subscriberId) && isValidNewsletterSubscriber(incoming());
      allow update, delete: if false;
    }

    // 5. Remedy Feedbacks: Everyone can view feedback; only authenticated reviewers can write
    match /remedy_feedbacks/{feedbackId} {
      allow read: if true; // Public listings allowed to show community remedy evaluations
      allow create: if isSignedIn() && isValidId(feedbackId) && isValidRemedyFeedback(incoming());
      allow update: if isSignedIn()
        && isValidId(feedbackId)
        && isValidRemedyFeedback(incoming())
        && existing().userId == request.auth.uid
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().productId == existing().productId
        && incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'rating', 'displayName']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // 6. Referrals collection: Tracking of invitations and sign-ups
    match /referrals/{referralId} {
      allow get: if isSignedIn() && (existing().referrerId == request.auth.uid || existing().friendEmail == request.auth.token.email);
      allow list: if isSignedIn() && (resource.data.referrerId == request.auth.uid || resource.data.friendEmail == request.auth.token.email);
      allow create: if isSignedIn() && isValidId(referralId) && isValidReferral(incoming()) && incoming().referrerId == request.auth.uid;
      allow update: if (
        isSignedIn()
        && isValidId(referralId)
        && incoming().referrerId == existing().referrerId
        && incoming().friendEmail == existing().friendEmail
        && incoming().friendName == existing().friendName
        && incoming().createdAt == existing().createdAt
        && (
          // Action 1: Referrer updates the status
          (existing().referrerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          // Action 2: Invitee converts to "joined"
          (incoming().status == 'joined' && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        )
      ) || (
        // Allow unauthenticated conversion (e.g. from the join us screen) but only to set status = 'joined'
        !isSignedIn()
        && isValidId(referralId)
        && incoming().referrerId == existing().referrerId
        && incoming().friendEmail == existing().friendEmail
        && incoming().friendName == existing().friendName
        && incoming().createdAt == existing().createdAt
        && incoming().status == 'joined'
        && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isSignedIn() && existing().referrerId == request.auth.uid;
    }

  }
}
